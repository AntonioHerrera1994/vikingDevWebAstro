---
import '../styles/footer.css'
const currentYear = new Date().getFullYear();

const links = {
  servicios: [
    { label: 'Desarrollo Web',        href: '#servicios' },
    { label: 'Google Ads & Meta Ads', href: '#servicios' },
    { label: 'Aplicaciones Web',      href: '#servicios' },
    { label: 'Consultoría Digital',   href: '#servicios' },
    { label: 'Paquetes y Precios',    href: '#paquetes'  },
  ],
  empresa: [
    { label: 'Portafolio VikingDev',  href: '#proyectos'  },
    { label: 'Portafolio Snitch',     href: '#proyectos'  },
    { label: 'Testimonios',           href: '#testimonios' },
    { label: 'Cotizador',             href: '#cotizador'  },
    { label: 'Ikari CRM',             href: 'https://ikaricrm.com/', external: true },
  ],
  contacto: [
    { label: '(663) 247-7816',        href: 'tel:+526632477816'                },
    { label: 'vikingdevtj@gmail.com', href: 'mailto:vikingdevtj@gmail.com'     },
    { label: 'WhatsApp',              href: 'https://wa.link/wnb0m6', external: true },
    { label: 'Tijuana, Baja California', href: null },
  ],
};

const social = [
  {
    label: 'Facebook',
    href: 'https://www.facebook.com/vikingdevtj',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/company/vikingdev/',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`,
  },
  {
    label: 'WhatsApp',
    href: 'https://wa.link/6xz219',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>`,
  },

];
import FooterLogo from '../assets/vikigdev-blanco.webp'
---

<footer class="footer" role="contentinfo" aria-label="Pie de página VikingDev">

  <!-- ── CTA final de conversión ──────────────────────────── -->
  <div class="footer__cta-band">
    <div class="container footer__cta-inner">
      <div class="footer__cta-copy">
        <h2 class="footer__cta-title">
          ¿Listo para llevar tu negocio al siguiente nivel?
        </h2>
        <p class="footer__cta-desc">
         Gestiona tus leads, citas y finanzas desde un solo sistema.
        </p>
      </div>
      <a
        href="https://ikaricrm.com/"
        class="footer__cta-btn"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Iniciar proyecto con VikingDev por WhatsApp"
      >
       Conoce Ikari
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- ── Body del footer ─────────────────────────────────── -->
  <div class="footer__body">
    <div class="container footer__grid">

      <!-- Columna 1: Logo + tagline + social -->
      <div class="footer__brand">
        <a href="/" class="footer__logo" aria-label="VikingDev — ir al inicio">
         <img 
         src={FooterLogo.src}
         width="150"
         alt="VikingDev Logo Blanco"
         />
        </a>
        <p class="footer__tagline">
          Agencia de desarrollo web y marketing digital en Tijuana.
          Construimos presencias digitales que generan resultados reales.
        </p>

        <!-- Redes sociales -->
        <div class="footer__social" aria-label="Redes sociales de VikingDev">
          {social.map((s) => (
            <a
              href={s.href}
              class="footer__social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              set:html={s.icon}
            />
          ))}
        </div>

        <!-- Partner badge -->
        <a
          href="https://snitchagency.com"
          class="footer__partner"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Snitch Agency — socio estratégico"
        >
          <span class="footer__partner-label">Partner</span>
          <span class="footer__partner-name">Snitch Agency</span>
          <span class="footer__partner-name"></span>
        </a>
        
      </div>

      <!-- Columna 2: Servicios -->
      <nav class="footer__nav" aria-label="Servicios">
        <h3 class="footer__nav-title">Servicios</h3>
        <ul class="footer__nav-list">
          {links.servicios.map((l) => (
            <li>
              <a href={l.href} class="footer__nav-link">{l.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Columna 3: Empresa -->
      <nav class="footer__nav" aria-label="Empresa">
        <h3 class="footer__nav-title">Empresa</h3>
        <ul class="footer__nav-list">
          {links.empresa.map((l) => (
            <li>
              <a
                href={l.href}
                class="footer__nav-link"
                target={l.external ? '_blank' : undefined}
                rel={l.external ? 'noopener noreferrer' : undefined}
              >
                {l.label}
                {l.external && (
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true" style="margin-left:4px;opacity:0.6;">
                    <line x1="7" y1="17" x2="17" y2="7"/>
                    <polyline points="7 7 17 7 17 17"/>
                  </svg>
                )}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Columna 4: Contacto -->
      <div class="footer__nav" aria-label="Contacto">
        <h3 class="footer__nav-title">Contacto</h3>
        <ul class="footer__nav-list">
          {links.contacto.map((l) => (
            <li>
              {l.href ? (
                <a
                  href={l.href}
                  class="footer__nav-link"
                  target={l.external ? '_blank' : undefined}
                  rel={l.external ? 'noopener noreferrer' : undefined}
                >
                  {l.label}
                </a>
              ) : (
                <span class="footer__nav-text">{l.label}</span>
              )}
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>

  <!-- ── Bottom bar ──────────────────────────────────────── -->
  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p class="footer__copy">
        © {currentYear} VikingDev. Todos los derechos reservados.
      </p>
      <nav class="footer__legal" aria-label="Legal">
        <a href="/aviso-de-privacidad" class="footer__legal-link">
          Aviso de Privacidad
        </a>
        <span class="footer__legal-sep" aria-hidden="true">·</span>
        <a href="/terminos-y-condiciones" class="footer__legal-link">
          Términos y Condiciones
        </a>
      </nav>
    </div>
  </div>

</footer>


<script>
    import '../scripts/footer'
</script>
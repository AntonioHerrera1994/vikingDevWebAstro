---

<section class="portfolio section" id="proyectos" aria-labelledby="portfolio-title">
  <div class="container">

    <!-- ══ Carrusel 1: VikingDev ══════════════════════════════ -->
    <div class="portfolio__block" data-carousel="vikingdev">

      <div class="portfolio__header">
        <div class="portfolio__header-left">
          <span class="section-label">Portafolio</span>
          <h2 class="section-title" id="portfolio-title">VikingDev</h2>
          <p class="section-subtitle">Proyectos de desarrollo web, e-commerce y aplicaciones.</p>
        </div>
        <div class="portfolio__nav" aria-label="Navegación carrusel VikingDev">
          <button class="portfolio__arrow portfolio__arrow--prev" aria-label="Proyecto anterior" type="button">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
          </button>
          <button class="portfolio__arrow portfolio__arrow--next" aria-label="Siguiente proyecto" type="button">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Track -->
      <div class="portfolio__viewport">
        <ul class="portfolio__track" role="list">
          {vikingProjects.map((p) => (
            <li class="portfolio__card" data-id={p.id}>
              <div class="portfolio__img-wrap">
                <img
                  src={p.image}
                  alt={p.imageAlt}
                  class="portfolio__img"
                  loading="lazy"
                  decoding="async"
                  width="480"
                  height="300"
                />
              </div>
              <div class="portfolio__card-body">
                <span class="portfolio__category">{p.category}</span>
                <h3 class="portfolio__card-title">{p.title}</h3>
                <p class="portfolio__card-desc">{p.desc}</p>
                <a
                  href={p.url}
                  class="portfolio__link"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Ver sitio web de ${p.title}`}
                >
                  Ver sitio web
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                  </svg>
                </a>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Dots -->
      <div class="portfolio__dots" aria-label="Posición en el carrusel"></div>
    </div>

    <!-- Divider -->
    <div class="portfolio__divider" aria-hidden="true"></div>

    <!-- ══ Carrusel 2: Snitch Agency ══════════════════════════ -->
    <div class="portfolio__block" data-carousel="snitch">

      <div class="portfolio__header">
        <div class="portfolio__header-left">
          <span class="section-label">Portafolio</span>
          <h2 class="section-title">Snitch Agency</h2>
          <p class="section-subtitle">Branding, marketing digital y estrategia creativa.</p>
        </div>
        <div class="portfolio__nav" aria-label="Navegación carrusel Snitch Agency">
          <button class="portfolio__arrow portfolio__arrow--prev" aria-label="Proyecto anterior" type="button">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
          </button>
          <button class="portfolio__arrow portfolio__arrow--next" aria-label="Siguiente proyecto" type="button">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </button>
        </div>
      </div>

      <div class="portfolio__viewport">
        <ul class="portfolio__track" role="list">
          {snitchProjects.map((p) => (
            <li class="portfolio__card" data-id={p.id}>
              <div class="portfolio__img-wrap">
                <img
                  src={p.image}
                  alt={p.imageAlt}
                  class="portfolio__img"
                  loading="lazy"
                  decoding="async"
                  width="480"
                  height="300"
                />
              </div>
              <div class="portfolio__card-body">
                <span class="portfolio__category">{p.category}</span>
                <h3 class="portfolio__card-title">{p.title}</h3>
                <p class="portfolio__card-desc">{p.desc}</p>
                <a
                  href={p.url}
                  class="portfolio__link"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Ver sitio web de ${p.title}`}
                >
                  Ver sitio web
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                  </svg>
                </a>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <div class="portfolio__dots" aria-label="Posición en el carrusel"></div>
    </div>

  </div>
</section>


        <div class="portfolio__nav" aria-label="Navegación carrusel Snitch Agency">
          <button class="portfolio__arrow portfolio__arrow--prev" aria-label="Proyecto anterior" type="button">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">

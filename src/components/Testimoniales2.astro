---
import '../styles/testimoniales.css'
const testimonials = [
  {
    id: 'bajabox',
    name: 'BajaBox',
    role: 'CEO',
    company: 'BajaBox',
    avatar: 'https://bajabox.com.mx/wp-content/uploads/2024/12/favicon-ok-150x150.png',
    rating: 5,
    quote: 'Hemos visto un aumento significativo en la eficiencia de nuestros procesos y una mejora en la satisfacción de nuestros clientes. El equipo de VikingDev entiende exactamente lo que un negocio necesita para crecer en digital. ¡Los recomendamos ampliamente!',
    accent: '#4cd7f6', // cyan
  },
  {
    id: 'ppsolutions',
    name: 'P&P Solutions',
    role: 'Director General',
    company: 'P&P Solutions',
    avatar: 'https://ppsolutions.com.mx/wp-content/uploads/2025/01/cropped-Logo-2-e1738261177163-192x192.png',
    rating: 5,
    quote: 'El diseño del sitio es moderno, elegante y transmite exactamente la confianza que buscábamos. Estamos muy satisfechos con el resultado y hemos recibido comentarios muy positivos de nuestros clientes desde el lanzamiento.',
    accent: '#6063ee', // indigo
  },
  {
    id: 'integra',
    name: 'Integra TJ',
    role: 'Directora',
    company: 'Integra TJ',
    avatar: 'https://integratj.com.mx/wp-content/uploads/2025/01/Diseno-sin-titulo-300x300.webp',
    rating: 5,
    quote: 'El sitio web es claro, conciso y fácil de navegar. Desde que lanzamos el nuevo sitio web, hemos notado un aumento considerable en las consultas de clientes potenciales. VikingDev cumplió cada detalle a tiempo.',
    accent: '#22c55e', // green
  },
  {
    id: 'zactech',
    name: 'Zac Tech Semi',
    role: 'Gerente Comercial',
    company: 'Zac Tech Semi',
    avatar: 'https://zacsemi.com.mx/favicon.png',
    rating: 5,
    quote: 'El sitio web ha sido una herramienta invaluable para atraer nuevos clientes y mejorar nuestra imagen corporativa. La velocidad, el diseño y el SEO superaron nuestras expectativas. Seguimos trabajando juntos.',
    accent: '#f59e0b', // amber
  },
  {
    id: 'favlash',
    name: 'Favlash',
    role: 'Fundadora',
    company: 'Favlash',
    avatar: 'https://favlash.com/favicon2.svg',
    rating: 5,
    quote: 'El diseño es vibrante y atractivo, las fotos de nuestros trabajos se ven increíbles, y el sistema de reservas online es súper fácil de usar. VikingDev lo entendió perfectamente desde el primer brief.',
    accent: '#ec4899', // pink
  },
];
---

<section class="testi section" id="testimonios" aria-labelledby="testi-title">
  <div class="testi__bg" aria-hidden="true">
    <!-- Blob decorativo animado -->
    <div class="testi__blob testi__blob--1"></div>
    <div class="testi__blob testi__blob--2"></div>
  </div>

  <div class="container testi__container">

    <!-- Header -->
    <header class="testi__header">
      <span class="testi__label">Testimonios</span>
      <h2 class="testi__title" id="testi-title">
        Lo que dicen nuestros clientes
      </h2>
      <p class="testi__subtitle">
        Más de 30 negocios en Tijuana y la región confían en VikingDev
        para crecer en digital.
      </p>
    </header>

    <!-- Carrusel -->
    <div class="testi__carousel" aria-label="Testimonios de clientes">

      <!-- Track -->
      <div class="testi__viewport">
        <ul class="testi__track" role="list" id="testi-track">
          {testimonials.map((t, i) => (
            <li
              class={`testi__slide${i === 0 ? ' is-active' : ''}`}
              data-index={i}
              data-accent={t.accent}
              role="group"
              aria-roledescription="slide"
              aria-label={`${i + 1} de ${testimonials.length}: ${t.company}`}
            >
              <div class="testi__card">
                <!-- Quote mark decorativo -->
                <div class="testi__quote-mark" aria-hidden="true">"</div>

                <!-- Rating -->
                <div class="testi__stars" aria-label={`${t.rating} de 5 estrellas`}>
                  {Array.from({ length: t.rating }).map(() => (
                    <span class="testi__star" aria-hidden="true">★</span>
                  ))}
                </div>

                <!-- Cita -->
                <blockquote class="testi__blockquote">
                  <p class="testi__quote">"{t.quote}"</p>
                </blockquote>

                <!-- Autor -->
                <div class="testi__author">
                  <div class="testi__avatar-wrap">
                    <img
                      src={t.avatar}
                      alt={`Avatar de ${t.name} — ${t.company}`}
                      class="testi__avatar"
                      width="56"
                      height="56"
                      loading="lazy"
                      decoding="async"
                    />
                    <!-- Accent ring -->
                    <span
                      class="testi__avatar-ring"
                      style={`--accent: ${t.accent}`}
                      aria-hidden="true"
                    ></span>
                  </div>
                  <div class="testi__author-info">
                    <p class="testi__author-name">{t.name}</p>
                    <p class="testi__author-role">{t.role} · {t.company}</p>
                  </div>
                </div>

                <!-- Accent line inferior -->
                <div
                  class="testi__accent-line"
                  style={`background: ${t.accent}`}
                  aria-hidden="true"
                ></div>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Flechas -->
      <div class="testi__controls" aria-label="Controles del carrusel">
        <button
          id="testi-prev"
          class="testi__arrow testi__arrow--prev"
          aria-label="Testimonio anterior"
          type="button"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
        </button>

        <!-- Dots -->
        <div class="testi__dots" id="testi-dots" role="tablist" aria-label="Seleccionar testimonio"></div>

        <button
          id="testi-next"
          class="testi__arrow testi__arrow--next"
          aria-label="Siguiente testimonio"
          type="button"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>
      </div>

      <!-- Progress bar auto-play -->
      <div class="testi__progress" aria-hidden="true">
        <div class="testi__progress-bar" id="testi-progress"></div>
      </div>

    </div>

  </div>
</section>


  <script>
      import "../scripts/testimoniales.js"
  </script>

---

<section class="pricing section" id="paquetes" aria-labelledby="pricing-title">
  <div class="container">

    <!-- Header -->
    <header class="pricing__header">
      <span class="section-label">Paquetes Web</span>
      <h2 class="section-title" id="pricing-title">
        La solución perfecta para tu negocio
      </h2>
      <p class="section-subtitle pricing__subtitle">
        Elige el plan que se adapta a tu etapa. Todos incluyen hosting por un año y soporte post-entrega.
      </p>
    </header>

    <!-- Tabs -->
    <div class="pricing__tabs" role="tablist" aria-label="Planes de precios">
      {plans.map((plan, i) => (
        <button
          class={`pricing__tab${i === 0 ? ' is-active' : ''}`}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-controls={`panel-${plan.id}`}
          id={`tab-${plan.id}`}
          data-index={i}
          type="button"
        >
          {plan.tab}
          {plan.tag === 'Más popular' && (
            <span class="pricing__tab-badge">★</span>
          )}
        </button>
      ))}
      <!-- Indicador deslizante del tab activo -->
      <span class="pricing__tab-indicator" aria-hidden="true"></span>
    </div>

    <!-- Panels -->
    <div class="pricing__panels">
      {plans.map((plan, i) => (
        <div
          class={`pricing__panel${i === 0 ? ' is-active' : ''}`}
          role="tabpanel"
          id={`panel-${plan.id}`}
          aria-labelledby={`tab-${plan.id}`}
          hidden={i !== 0}
        >
          <div class="pricing__panel-inner">

            <!-- Imagen con precio superpuesto -->
            <div class="pricing__img-col">
              <div class="pricing__img-wrap">
                <img
                  src={plan.image}
                  alt={plan.imageAlt}
                  class="pricing__img"
                  loading={i === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                  width="600"
                  height="480"
                />
                <!-- Overlay gradiente -->
                <div class="pricing__img-overlay" aria-hidden="true"></div>
                <!-- Precio superpuesto -->
                <div class="pricing__img-content">
                  <span class="pricing__img-tag">{plan.tag}</span>
                  <p class="pricing__img-period">
                    {plan.period === '/ mes' ? 'Suscripción mensual:' : 'Inversión:'}
                  </p>
                  <p class="pricing__img-price">
                    {plan.price}
                    <span class="pricing__img-currency"> {plan.currency}</span>
                  </p>
                  <p class="pricing__img-desc">{plan.desc}</p>
                </div>
              </div>
            </div>

            <!-- Features + CTA -->
            <div class="pricing__info-col">
              <p class="pricing__includes-label">¿Qué incluye?</p>

              <div class="pricing__features-wrap">
                <ul class="pricing__features" aria-label={`Características del plan ${plan.tab}`}>
                  {plan.features.map((feat) => (
                    <li class="pricing__feature">
                      <span class="pricing__dot" aria-hidden="true"></span>
                      {feat}
                    </li>
                  ))}
                </ul>
              </div>

              <a
                href={plan.ctaHref}
                class="pricing__cta"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Contratar plan ${plan.tab}`}
              >
                {plan.cta}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
            </div>

          </div>
        </div>
      ))}
    </div>

    <!-- Nota pie -->
    <p class="pricing__note">
      ¿Proyecto especial o a medida?
      <a href="https://wa.link/wnb0m6" class="pricing__note-link" target="_blank" rel="noopener noreferrer">
        Hablemos →
      </a>
    </p>

  </div>
</section>

<script>
  import '../scripts/costos'
</script>
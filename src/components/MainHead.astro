---
import '../styles/mainhead.css'
---
---

<section class="hero hero-gradient" aria-label="VikingDev — Agencia de desarrollo web en Tijuana">
  <div class="container hero__inner">

    <!-- ─── Columna izquierda: copy ──────────────────────── -->
    <div class="hero__copy">

      <span class="hero__badge">
        Agencia de Desarrollo Web en Tijuana · +30 proyectos entregados
      </span>

      <h1 class="hero__h1">
        Más que sitios web: Estrategias escalables que
        <span class="hero__accent">impulsan</span>.
      </h1>

      <p class="hero__sub">
        Transformamos la operación de tu negocio. Desarrollamos sitios web y
        aplicaciones a medida, automatizamos procesos con CRM avanzado y
        aceleramos tus ventas con campañas rentables en Google y Meta Ads.
      </p>

      <div class="hero__actions">
        <a href="#cotizador" class="btn btn--primary hero__btn-primary">
          Cotiza Tu Proyecto
        </a>
        <a href="#proyectos" class="btn btn--outline hero__btn-outline">
          Ver Portafolio
        </a>
      </div>

      <p class="hero__proof">
        <span class="hero__proof-dot" aria-hidden="true"></span>
        Respuesta en menos de 24 hrs · Tijuana, Baja California
      </p>

    </div>

    <!-- ─── Columna derecha: 4 SVG animados ─────────────── -->
    <div class="hero__visual" aria-hidden="true">

      <div class="hero__blob"></div>

      <div class="hero__cards-grid">

        <!-- Card 1: Desarrollo Web -->
        <div class="hero__illus-card" data-card="0">
          <div class="hero__illus-wrap">
            <!-- Stroke SVG (se traza) -->
            <svg class="hero__svg hero__svg--stroke" viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="12" y="10" width="136" height="82" rx="8" stroke="var(--color-secondary)" stroke-width="3"/>
              <rect x="22" y="20" width="116" height="62" rx="4" stroke="var(--color-secondary)" stroke-width="2" stroke-dasharray="4 2"/>
              <line x1="80" y1="92" x2="80" y2="108" stroke="var(--color-secondary)" stroke-width="3" stroke-linecap="round"/>
              <line x1="56" y1="108" x2="104" y2="108" stroke="var(--color-secondary)" stroke-width="3" stroke-linecap="round"/>
              <line x1="32" y1="38" x2="68" y2="38" stroke="var(--color-tertiary-fixed-dim)" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="32" y1="50" x2="90" y2="50" stroke="var(--color-tertiary-fixed-dim)" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="32" y1="62" x2="75" y2="62" stroke="var(--color-tertiary-fixed-dim)" stroke-width="2.5" stroke-linecap="round"/>
              <polyline points="100,34 108,44 100,54" stroke="var(--color-secondary-container)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              <polyline points="118,34 110,44 118,54" stroke="var(--color-secondary-container)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <!-- Fill SVG (aparece después) -->
            <svg class="hero__svg hero__svg--fill" viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="12" y="10" width="136" height="82" rx="8" fill="var(--color-secondary)" fill-opacity="0.08"/>
              <rect x="22" y="20" width="116" height="62" rx="4" fill="var(--color-secondary)" fill-opacity="0.05"/>
            </svg>
          </div>
          <span class="hero__illus-label">Desarrollo Web</span>
        </div>

        <!-- Card 2: Google & Meta Ads -->
        <div class="hero__illus-card" data-card="1">
          <div class="hero__illus-wrap">
            <svg class="hero__svg hero__svg--stroke" viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
              <line x1="20" y1="100" x2="140" y2="100" stroke="var(--color-secondary)" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="20" y1="100" x2="20" y2="15" stroke="var(--color-secondary)" stroke-width="2.5" stroke-linecap="round"/>
              <rect x="32" y="72" width="16" height="28" rx="3" stroke="var(--color-secondary-container)" stroke-width="2"/>
              <rect x="58" y="52" width="16" height="48" rx="3" stroke="var(--color-secondary-container)" stroke-width="2"/>
              <rect x="84" y="38" width="16" height="62" rx="3" stroke="var(--color-secondary-container)" stroke-width="2"/>
              <rect x="110" y="22" width="16" height="78" rx="3" stroke="var(--color-secondary-container)" stroke-width="2"/>
              <polyline points="40,76 66,56 92,42 118,26" stroke="var(--color-tertiary-fixed-dim)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="40" cy="76" r="4" stroke="var(--color-tertiary-fixed-dim)" stroke-width="2"/>
              <circle cx="66" cy="56" r="4" stroke="var(--color-tertiary-fixed-dim)" stroke-width="2"/>
              <circle cx="92" cy="42" r="4" stroke="var(--color-tertiary-fixed-dim)" stroke-width="2"/>
              <circle cx="118" cy="26" r="4" stroke="var(--color-tertiary-fixed-dim)" stroke-width="2"/>
              <polyline points="128,20 138,10 148,20" stroke="var(--color-tertiary-fixed-dim)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <svg class="hero__svg hero__svg--fill" viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="32" y="72" width="16" height="28" rx="3" fill="var(--color-secondary-container)" fill-opacity="0.15"/>
              <rect x="58" y="52" width="16" height="48" rx="3" fill="var(--color-secondary-container)" fill-opacity="0.22"/>
              <rect x="84" y="38" width="16" height="62" rx="3" fill="var(--color-secondary-container)" fill-opacity="0.28"/>
              <rect x="110" y="22" width="16" height="78" rx="3" fill="var(--color-secondary-container)" fill-opacity="0.35"/>
            </svg>
          </div>
          <span class="hero__illus-label">Google &amp; Meta Ads</span>
        </div>

        <!-- Card 3: CRM -->
        <div class="hero__illus-card" data-card="2">
          <div class="hero__illus-wrap">
            <svg class="hero__svg hero__svg--stroke" viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="80" cy="60" r="18" stroke="var(--color-secondary)" stroke-width="2.5"/>
              <circle cx="80" cy="54" r="6" stroke="var(--color-secondary)" stroke-width="2"/>
              <path d="M68 72 Q80 66 92 72" stroke="var(--color-secondary)" stroke-width="2" stroke-linecap="round"/>
              <circle cx="30" cy="24" r="12" stroke="var(--color-secondary-container)" stroke-width="2"/>
              <circle cx="130" cy="24" r="12" stroke="var(--color-secondary-container)" stroke-width="2"/>
              <circle cx="20" cy="96" r="12" stroke="var(--color-secondary-container)" stroke-width="2"/>
              <circle cx="140" cy="96" r="12" stroke="var(--color-secondary-container)" stroke-width="2"/>
              <line x1="42" y1="32" x2="64" y2="47" stroke="var(--color-tertiary-fixed-dim)" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="3 3"/>
              <line x1="118" y1="32" x2="96" y2="47" stroke="var(--color-tertiary-fixed-dim)" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="3 3"/>
              <line x1="32" y1="84" x2="64" y2="70" stroke="var(--color-tertiary-fixed-dim)" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="3 3"/>
              <line x1="128" y1="84" x2="96" y2="70" stroke="var(--color-tertiary-fixed-dim)" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="3 3"/>
              <polyline points="25,24 29,28 36,20" stroke="var(--color-tertiary-fixed-dim)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <polyline points="125,24 129,28 136,20" stroke="var(--color-tertiary-fixed-dim)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <svg class="hero__svg hero__svg--fill" viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="80" cy="60" r="18" fill="var(--color-secondary)" fill-opacity="0.08"/>
              <circle cx="30" cy="24" r="12" fill="var(--color-secondary-container)" fill-opacity="0.12"/>
              <circle cx="130" cy="24" r="12" fill="var(--color-secondary-container)" fill-opacity="0.12"/>
              <circle cx="20" cy="96" r="12" fill="var(--color-secondary-container)" fill-opacity="0.12"/>
              <circle cx="140" cy="96" r="12" fill="var(--color-secondary-container)" fill-opacity="0.12"/>
            </svg>
          </div>
          <span class="hero__illus-label">CRM &amp; Automatización</span>
        </div>

        <!-- Card 4: Consultoría Digital -->
        <div class="hero__illus-card" data-card="3">
          <div class="hero__illus-wrap">
            <svg class="hero__svg hero__svg--stroke" viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="68" cy="58" r="30" stroke="var(--color-secondary)" stroke-width="3"/>
              <circle cx="68" cy="58" r="20" stroke="var(--color-secondary)" stroke-width="1.5" stroke-dasharray="3 3"/>
              <line x1="91" y1="81" x2="114" y2="104" stroke="var(--color-secondary)" stroke-width="3.5" stroke-linecap="round"/>
              <polyline points="52,66 60,56 68,60 76,48" stroke="var(--color-tertiary-fixed-dim)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="52" cy="66" r="2.5" stroke="var(--color-tertiary-fixed-dim)" stroke-width="1.5"/>
              <circle cx="60" cy="56" r="2.5" stroke="var(--color-tertiary-fixed-dim)" stroke-width="1.5"/>
              <circle cx="68" cy="60" r="2.5" stroke="var(--color-tertiary-fixed-dim)" stroke-width="1.5"/>
              <circle cx="76" cy="48" r="2.5" stroke="var(--color-tertiary-fixed-dim)" stroke-width="1.5"/>
              <path d="M128 20 L131 29 L140 29 L133 35 L136 44 L128 38 L120 44 L123 35 L116 29 L125 29 Z" stroke="var(--color-secondary-container)" stroke-width="2" stroke-linejoin="round"/>
            </svg>
            <svg class="hero__svg hero__svg--fill" viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="68" cy="58" r="30" fill="var(--color-secondary)" fill-opacity="0.06"/>
              <path d="M128 20 L131 29 L140 29 L133 35 L136 44 L128 38 L120 44 L123 35 L116 29 L125 29 Z" fill="var(--color-secondary-container)" fill-opacity="0.22"/>
            </svg>
          </div>
          <span class="hero__illus-label">Consultoría Digital</span>
        </div>

      </div>
    </div>

  </div>
</section>

<script>
  import '../scripts/header'
</script>
---
import '../styles/servicios.css'
import {Image} from 'astro:assets';
import MetodoImg from '../assets/metodo.webp';
import myImageS2 from '../assets/d-movil.webp';
import myImage3 from '../assets/googleads.webp';
import LogoSnitch from '../assets/snitch-logo.png'
import DefineLogo from '../assets/definelogo.png';
import IkariImg from '../assets/logoblanco.png'
---
<section class="ikari" aria-labelledby="ikari-title">
  <div class="container ikari__inner">
 
    <!-- ─── Columna izquierda: imagen + stat ──────────────── -->
    <div class="ikari__visual">

        <img src={MetodoImg.src} alt="..." class="ikari__img" />
     
     
 
      <!-- Stat flotante -->
      <div class="ikari__stat" aria-label="45% mejora en tiempo de respuesta a leads">
        <p class="ikari__stat-number">+45<span class="ikari__stat-pct">%</span></p>
        <p class="ikari__stat-label">Lead Response Time</p>
      </div>
    </div>
 
    <!-- ─── Columna derecha: copy ─────────────────────────── -->
    <div class="ikari__copy">
 
      <!-- Logo Ikari (placeholder — reemplaza el img src) -->
      <a
        href="https://ikari.mx"
        class="ikari__logo-link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Visitar Ikari — CRM para agencias digitales"
      >
  
       
          <img src={IkariImg.src} alt="Ikari" class="ikari__logo" />
      
      </a>
 
      <!-- Label -->
      <span class="ikari__label">Integración Exclusiva</span>
 
      <!-- H2 -->
      <h2 class="ikari__title" id="ikari-title">
        Control total de<br />
        tus leads con CRM.
      </h2>
 
      <!-- Descripción -->
      <p class="ikari__desc">
        No solo generamos tráfico; cerramos el ciclo. Nuestra integración
        personalizada conecta tus landings con Ikari en tiempo real para que
        ningún lead se pierda en el camino.
      </p>
 
      <!-- Iconos de beneficios -->
      <div class="ikari__benefits">
 
        <div class="ikari__benefit">
          <span class="ikari__benefit-icon" aria-hidden="true">
            <!-- Rayo / instantáneo -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
            </svg>
          </span>
          <div>
            <p class="ikari__benefit-title">Respuesta Instantánea</p>
            <p class="ikari__benefit-desc">Notificaciones en segundos.</p>
          </div>
        </div>
 
        <div class="ikari__benefit">
          <span class="ikari__benefit-icon" aria-hidden="true">
            <!-- Analytics / atribución -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="20" x2="18" y2="10"/>
              <line x1="12" y1="20" x2="12" y2="4"/>
              <line x1="6"  y1="20" x2="6"  y2="14"/>
              <line x1="2"  y1="20" x2="22" y2="20"/>
            </svg>
          </span>
          <div>
            <p class="ikari__benefit-title">Atribución Exacta</p>
            <p class="ikari__benefit-desc">Sabe de dónde viene cada venta.</p>
          </div>
        </div>
 
        <div class="ikari__benefit">
          <span class="ikari__benefit-icon" aria-hidden="true">
            <!-- Sincronización -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="23 4 23 10 17 10"/>
              <polyline points="1 20 1 14 7 14"/>
              <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
            </svg>
          </span>
          <div>
            <p class="ikari__benefit-title">Sincronización en Tiempo Real</p>
            <p class="ikari__benefit-desc">Leads en tu CRM al instante.</p>
          </div>
        </div>
 
        <div class="ikari__benefit">
          <span class="ikari__benefit-icon" aria-hidden="true">
            <!-- Pipeline -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <line x1="3"  y1="9"  x2="21" y2="9"/>
              <line x1="3"  y1="15" x2="21" y2="15"/>
              <line x1="9"  y1="3"  x2="9"  y2="21"/>
            </svg>
          </span>
          <div>
            <p class="ikari__benefit-title">Pipeline Visual</p>
            <p class="ikari__benefit-desc">Visualiza el estado de cada oportunidad.</p>
          </div>
        </div>
 
      </div>
 
      <!-- CTA -->
      <a
        href="https://ikari.mx"
        class="ikari__cta"
        target="_blank"
        rel="noopener noreferrer"
      >
        Conocer Ikari
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
 
    </div>
  </div>
</section>
 
<script>
    import '../scripts/ikari'
</script>
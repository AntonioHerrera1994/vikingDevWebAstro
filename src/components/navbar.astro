---
import '../styles/navbar.css'
import ImageLogo from '../assets/vikingdev-logo.webp';
---

 
<nav id="main-nav" class="nav" aria-label="Navegación principal">
  <div class="container nav__inner">
 
    <!-- Logo -->
    <a href="/" class="nav__logo" aria-label="VikingDev — Ir al inicio">
      <img 
      src={ImageLogo.src}
      width="150"
      />
    </a>
 
    <!-- Links desktop -->
    <ul class="nav__links" role="list">
      <li><a href="#servicios"  class="nav__link">Servicios</a></li>
      <li><a href="#proyectos"  class="nav__link">Proyectos</a></li>
      <li><a href="#cotizador"  class="nav__link">Cotizador</a></li>
      <li><a href="#paquetes"   class="nav__link">Paquetes</a></li>
      <li><a href="#seo"        class="nav__link nav__link--active">SEO &amp; Ads</a></li>
    </ul>
 
    <!-- CTA desktop -->
    <a href="#cotizador" class="btn btn--dark nav__cta">
      Cotiza Gratis
    </a>
 
    <!-- Hamburger mobile -->
    <button
      id="nav-hamburger"
      class="nav__hamburger"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-menu"
      type="button"
    >
      <span class="nav__bar" aria-hidden="true"></span>
      <span class="nav__bar" aria-hidden="true"></span>
      <span class="nav__bar" aria-hidden="true"></span>
    </button>
 
  </div>
 
  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="nav__mobile"
    role="dialog"
    aria-modal="true"
    aria-label="Menú móvil"
    aria-hidden="true"
  >
    <ul class="nav__mobile-list" role="list">
      <li><a href="#servicios" class="nav__mobile-link">Servicios</a></li>
      <li><a href="#proyectos" class="nav__mobile-link">Proyectos</a></li>
      <li><a href="#cotizador" class="nav__mobile-link">Cotizador</a></li>
      <li><a href="#paquetes"  class="nav__mobile-link">Paquetes</a></li>
      <li><a href="#seo"       class="nav__mobile-link">SEO &amp; Ads</a></li>
    </ul>
    <a href="#cotizador" class="btn btn--primary nav__mobile-cta">
      Cotiza Tu Proyecto Gratis →
    </a>
  </div>
</nav>


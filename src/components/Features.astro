---
 
<section class="services section" id="servicios" aria-labelledby="services-title">
  <div class="container">
 
    <header class="services__header">
      <span class="section-label">Nuestros Servicios</span>
      <h2 class="section-title" id="services-title">
        Soluciones digitales de alto impacto
      </h2>
      <p class="section-subtitle services__subtitle">
        Desde el diseño de tu sitio hasta la estrategia que llena tu agenda —
        todo bajo un mismo techo en Tijuana.
      </p>
    </header>
 
    <ul class="services__grid" role="list">
      {services.map((svc, i) => (
        <li
          class="services__card"
          data-index={i}
          data-service={svc.id}
          data-title={svc.title}
          data-tag={svc.tag}
          data-tagline={svc.tagline}
          data-desc={svc.modalDesc}
          data-features={JSON.stringify(svc.features)}
          data-cta={svc.cta}
          data-cta-href={svc.ctaHref}
          data-from={svc.from}
          data-img={svc.image}
          data-img-alt={svc.imageAlt}
          role="button"
          tabindex="0"
          aria-haspopup="dialog"
          aria-label={`Ver detalles de ${svc.title}`}
        >
          <div class="services__img-wrap">
            <img
              src={svc.image}
              alt={svc.imageAlt}
              class="services__img"
              width={600}
              height={400}
              loading="lazy"
              decoding="async"
            />
            <span class="services__tag">{svc.tag}</span>
            <div class="services__overlay" aria-hidden="true">
              <span class="services__overlay-label">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
                  <circle cx="11" cy="11" r="8"/>
                  <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                Ver detalle
              </span>
            </div>
          </div>
 
          <div class="services__copy">
            <h3 class="services__title">{svc.title}</h3>
            <p class="services__tagline">{svc.tagline}</p>
            <span class="services__from">{svc.from}</span>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
 
<!-- MODAL / SHEET -->
<div
  id="services-modal"
  class="svc-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
  aria-hidden="true"
>
  <div class="svc-modal__backdrop" id="modal-backdrop" aria-hidden="true"></div>
 
  <div class="svc-modal__panel" id="modal-panel">
    <div class="svc-modal__handle" aria-hidden="true"></div>
 
    <button class="svc-modal__close" id="modal-close" aria-label="Cerrar" type="button">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
 
    <div class="svc-modal__img-wrap">
      <img id="modal-img" src="" alt="" class="svc-modal__img" width="800" height="380" loading="lazy" decoding="async" />
      <span class="svc-modal__img-tag" id="modal-img-tag"></span>
    </div>
 
    <div class="svc-modal__body">
      <h3 class="svc-modal__title" id="modal-title"></h3>
      <p class="svc-modal__desc" id="modal-desc"></p>
      <p class="svc-modal__includes-label">¿Qué incluye?</p>
      <ul class="svc-modal__features" id="modal-features"></ul>
      <div class="svc-modal__footer">
        <span class="svc-modal__price" id="modal-price"></span>
        <a href="#cotizador" class="btn btn--primary svc-modal__cta" id="modal-cta"></a>
      </div>
    </div>
  </div>
</div>


<script>
  import '../scripts/servicios'
</script>

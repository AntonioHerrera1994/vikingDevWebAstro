    imageAlt: 'Desarrollo web y e-commerce en Tijuana — VikingDev',
    tag: 'Desarrollo',
    title: 'Desarrollo Web & E-Commerce',
    tagline: 'Sitios rápidos, modernos y diseñados para vender.',
    modalDesc: 'Construimos tu presencia digital desde cero o rediseñamos lo que ya tienes. Cada proyecto es personalizado, optimizado para Google y entregado listo para convertir visitantes en clientes reales.',
    features: [
      'Diseño 100% personalizado basado en tu marca',
      'Responsive Mobile First (móvil, tablet, desktop)',
      'Velocidad de carga < 2 segundos (Core Web Vitals)',
      'SEO técnico on-page incluido desde el inicio',
      'Panel autogestionable (CMS) sin conocimientos técnicos',
      'Formularios, WhatsApp flotante y CTAs estratégicos',
      'Google Analytics + Meta Pixel integrados',
      'E-Commerce con carrito, checkout y pasarelas de pago',
      'Hasta 3 rondas de revisión sin costo extra',
    ],
    cta: 'Ver paquetes de precios',
    ctaHref: '#paquetes',
    from: 'Desde $4,000 MXN',
  },
  {
    id: 'ads',
    image: 'https://raw.githubusercontent.com/AntonioHerrera1994/vikingDevWebAstro/main/src/assets/googleads.webp',
    imageAlt: 'Campañas de Google Ads y Meta Ads — VikingDev Tijuana',
    tag: 'Publicidad Digital',
    title: 'Google Ads & Meta Ads',
    tagline: 'Tus clientes ideales, en el momento exacto.',
    modalDesc: 'Gestionamos campañas de pago en Google y Facebook/Instagram con segmentación quirúrgica y optimización continua. Tu presupuesto trabaja al máximo, sin desperdicio.',
    features: [
      'Configuración y auditoría de cuenta desde cero',
      'Campañas Search, Display, Shopping y YouTube',
      'Anuncios en Facebook, Instagram y Reels',
      'Segmentación por ubicación, intereses y comportamiento',
      'Retargeting y audiencias personalizadas',
      'Creatividades diseñadas para conversión',
      'A/B testing de anuncios y landing pages',
      'Reporte mensual detallado con métricas clave',
      'Reunión de seguimiento mensual incluida',
    ],
    cta: 'Solicitar propuesta',
    ctaHref: '#cotizador',
    from: 'Desde $1,800 MXN / mes',
  },
  {
    id: 'apps',
    image: 'https://raw.githubusercontent.com/AntonioHerrera1994/vikingDevWebAstro/main/src/assets/d-movil.webp',
    imageAlt: 'Desarrollo de aplicaciones web a medida — VikingDev',
    tag: 'Desarrollo',
    title: 'Aplicaciones Web',
    tagline: 'Tecnología a medida para automatizar y escalar.',
    modalDesc: 'Desarrollamos herramientas web internas o productos digitales que resuelven problemas específicos de tu negocio: desde paneles de gestión hasta plataformas con lógica compleja.',
    features: [
      'Análisis y diseño de solución a medida',
      'Dashboards y paneles de administración internos',
      'Integraciones con APIs externas (CRM, ERP, pagos)',
      'Automatización de flujos y notificaciones',
      'Autenticación de usuarios y control de accesos',
      'Base de datos escalable y segura',
      'Despliegue en la nube con alta disponibilidad',
      'Documentación y capacitación al equipo',
      'Mantenimiento y soporte post-lanzamiento',
    ],
    cta: 'Cuéntanos tu idea',
    ctaHref: '#cotizador',
    from: 'Cotización a medida',
  },
  {
    id: 'consultoria',
    image: 'https://raw.githubusercontent.com/AntonioHerrera1994/vikingDevWebAstro/main/src/assets/apoyoweb.webp',
    imageAlt: 'Consultoría digital y auditoría SEO en Tijuana — VikingDev',
    tag: 'Consultoría',
    title: 'Consultoría Digital',
    tagline: '¿Tu web no convierte? Te decimos exactamente por qué.',
    modalDesc: 'Si ya tienes presencia digital pero no está generando resultados, nuestro servicio de consultoría te da claridad: diagnóstico experto, recomendaciones priorizadas y un plan de acción concreto. No requiere contratación de desarrollo.',
    features: [
      'Auditoría SEO técnica completa (on-page y off-page)',
      'Análisis de velocidad y Core Web Vitals',
      'Revisión de campañas de Google Ads y Meta Ads activas',
      'Análisis de competencia y palabras clave estratégicas',
      'Revisión de estructura, UX y copy del sitio',
      'Reporte con hallazgos priorizados por impacto',
      'Sesión 1-a-1 con experto para revisar resultados',
      'Plan de acción en 30 / 60 / 90 días',
      'Seguimiento de implementación (opcional)',
    ],
    cta: 'Agendar diagnóstico',
    ctaHref: '#cotizador',
    from: 'Desde $2,00 MXN',
  },

---
import Image404 from '../assets/vikingdev-logo.webp';
---
<html lang="es">
<head>
   
    <title>Página no encontrada | Ikari CRM</title>

<meta name="robots" content="noindex, nofollow" />

    
    <!-- Fonts (considera usar font-display: swap) -->
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    

</head>
	<body>
    <section class="general404">
    <div class="logo-404">
        <img 
        src={Image404.src}
        width="12%"
        height="50%"
        alt="favlash-logo"/>
      </div>
  <main style="text-align: center; padding: 50px; min-height: 70vh; display: flex; flex-direction: column; justify-content: center; align-items: center;">
    <h1 style="font-size: 4em; color: #333;">¡404!</h1>
    <p style="font-size: 1.5em; color: #666; margin-bottom: 20px;">Lo sentimos, la página que buscas no existe.</p>
    <p>Parece que te has perdido en el espacio...</p>
    <a href="/" style="display: inline-block; padding: 10px 20px; background-color: #0982A8; color: white; text-decoration: none; border-radius: 5px; margin-top: 30px;">
      Volver a la página de inicio
    </a>
  </main>
</section>


<style>
  
  .general404{
    height: 100vh;
  }

  main {
    font-family: "Roboto", sans-serif;
  }
  h1 {
    margin-bottom: 0.2em;
    margin-top: -15rem;
  }
  a:hover {
    background-color: #0056b3;
  }

  .logo-404{
    display: flex;
    justify-content: center;
    margin-top: 5rem;
  }
</style>

</body>
</html>
